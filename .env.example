# ─────────────────────────────────────────────────────────────────────────────
# Oxerfy — Environment Variables
#
# Copy this file to .env and fill in every value before running locally.
# In production (Vercel), set these in the Vercel Environment Variables panel.
# NEVER commit a .env file with real values to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase Client SDK (VITE_ prefix = exposed to the browser bundle) ────────
# These are non-secret "public" identifiers that Firebase uses to locate your
# project.  They are NOT service-account keys.  Access control is enforced by
# Firestore Security Rules, not by hiding these values.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ── Web3Forms (contact-form email forwarding) ─────────────────────────────────
# Obtain from https://web3forms.com/
VITE_WEB3FORMS_KEY=

# ── App URL ───────────────────────────────────────────────────────────────────
VITE_APP_URL=https://oxerfy.com

# ── SERVER-SIDE ONLY — never prefix these with VITE_ ─────────────────────────
# FIREBASE_ADMIN_SERVICE_ACCOUNT=
# GEMINI_API_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
